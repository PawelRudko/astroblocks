---
import Layout from '../../layouts/Layout.astro';
import HeroSplit from '../../components/sections/HeroSplit.astro';
import TeamGrid from '../../components/sections/TeamGrid.astro';
import HeroCentered from '../../components/sections/HeroCentered.astro';
import HeroGallery from '../../components/sections/HeroGallery.astro';
import HeroMarquee from '../../components/sections/HeroMarquee.astro';
import FeatureTabs from '../../components/sections/FeatureTabs.astro';
import Pricing from '../../components/sections/Pricing.astro';
import Testimonial from '../../components/sections/Testimonial.astro';
import Logos from '../../components/sections/Logos.astro';
import EventHeader from '../../components/sections/EventHeader.astro';
import Contact from '../../components/sections/Contact.astro';
import FeatureStackCards from '../../components/sections/FeatureStackCards.astro';
import FeatureStackSections from '../../components/sections/FeatureStackSections.astro';
import FeatureExpand from '../../components/sections/FeatureExpand.astro';
import BlogGrid from '../../components/sections/BlogGrid.astro';
import FAQ from '../../components/sections/FAQ.astro';
import CardHover from '../../components/sections/CardHover.astro';
import CardList from '../../components/sections/CardList.astro';
import NavBar from '../../components/sections/NavBar.astro';
import { registry } from '../../data/sections';

export function getStaticPaths() {
  return registry.map((s) => ({ params: { id: s.id }, props: { entry: s } }));
}

const { entry } = Astro.props;
const components: Record<string, any> = {
  'hero-split': HeroSplit,
  'team-grid': TeamGrid,
  'hero-centered': HeroCentered,
  'hero-gallery': HeroGallery,
  'hero-marquee': HeroMarquee,
  'feature-tabs': FeatureTabs,
  'pricing': Pricing,
  'testimonial': Testimonial,
  'logos': Logos,
  'event-header': EventHeader,
  'contact': Contact,
  'feature-stack-cards': FeatureStackCards,
  'feature-stack-sections': FeatureStackSections,
  'feature-expand': FeatureExpand,
  'blog-grid': BlogGrid,
  'faq': FAQ,
  'card-hover': CardHover,
  'card-list': CardList,
  'navbar': NavBar,
};
const Comp = components[entry.id];
---

<Layout title={`${entry.name} – preview`}>
  <a class="pv-back" href="/blocks">
    <span class="pv-back__arrow" aria-hidden="true">←</span> Back to blocks
  </a>
  <main style="width:100%">
    <Comp {...entry.demo} />
  </main>
</Layout>

<script is:inline>
  // In the thumbnail (iframe in the gallery) we hide the "Back to blocks" button
  if (window.self !== window.top) {
    document.documentElement.classList.add('is-embed');
  }
</script>

<style>
  .pv-back {
    position: fixed; top: 16px; left: 16px; z-index: 100;
    display: inline-flex; align-items: center; gap: 0.45rem;
    padding: 0.5rem 0.95rem;
    background: #fff; border: 1px solid var(--line-strong); border-radius: 999px;
    font-family: var(--font-body); font-size: 0.85rem; font-weight: 500; color: var(--text);
    box-shadow: 0 8px 24px -10px rgba(20, 20, 30, 0.28);
    transition: color 0.18s ease, border-color 0.18s ease, gap 0.18s ease;
  }
  .pv-back:hover { color: #5b5bd6; border-color: #5b5bd6; gap: 0.65rem; }
  .pv-back__arrow { transition: transform 0.18s ease; }
  .pv-back:hover .pv-back__arrow { transform: translateX(-3px); }
  :global(html.is-embed) .pv-back { display: none; }
</style>
