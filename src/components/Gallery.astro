---
// Gallery — filters + grid of blocks. Scales to hundreds:
//  • preview iframes are lazy-mounted (only cards near the viewport load one)
//  • the Copy button fetches the block source on demand from /raw/<id> (nothing inlined)
//  • numbered pagination (windowed) so the initial render stays light
// Used on / (teaser) and /blocks (full). Live-editable — see AGENTS.md.
interface Card { id: string; name: string; category: string; file: string; label: string }
interface Props { cards: Card[]; showFilters?: boolean; pageSize?: number }
const { cards, showFilters = true, pageSize = 12 } = Astro.props;

const categories = ['All', ...Array.from(new Set(cards.map((c) => c.category)))];
const countFor = (cat: string) => (cat === 'All' ? cards.length : cards.filter((c) => c.category === cat).length);
---

<div class="gallery-root">
  {showFilters && (
    <div class="filters" role="tablist" aria-label="Categories">
      {categories.map((c, i) => (
        <button class:list={['chip', { 'chip--active': i === 0 }]} data-filter={c} role="tab" aria-selected={i === 0}>
          {c} <span class="chip__count">{countFor(c)}</span>
        </button>
      ))}
    </div>
  )}

  <div class="grid" data-page-size={pageSize}>
    {cards.map((s, i) => (
      <article class="tcard" data-category={s.category} style={`--d:${(i % pageSize) * 45}ms`}>
        <div class="tcard__thumb" role="button" tabindex="0" data-preview={`/preview/${s.id}`} aria-label={`Preview: ${s.name}`}></div>
        <div class="tcard__body">
          <span class="tcard__label">{s.label}</span>
          <div class="tcard__actions">
            <button class="btn btn--primary btn--sm" data-copy-src={`/raw/${s.id}`}>
              <svg class="btn__ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
              <span class="btn__label">Copy</span>
            </button>
            <button class="btn btn--ghost btn--sm" type="button" data-preview={`/preview/${s.id}`}>Preview →</button>
          </div>
        </div>
      </article>
    ))}
  </div>

  {showFilters && <nav class="gpages" aria-label="Pagination" hidden></nav>}
</div>

<style>
  .filters { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; }
  .chip { display: inline-flex; align-items: center; gap: 0.45rem; padding: 0.5rem 0.95rem; border: 1px solid var(--line-strong); background: var(--surface); border-radius: var(--radius-btn); font-size: 0.9rem; font-weight: 500; cursor: pointer; color: var(--text); transition: background 0.15s ease, border-color 0.15s ease; font-family: var(--font-body); }
  .chip:hover { border-color: var(--text); }
  .chip--active { background: var(--ink); color: #fff; border-color: var(--ink); }
  .chip__count { font-family: var(--font-mono); font-size: 0.72rem; opacity: 0.6; }
  .chip--active .chip__count { opacity: 0.8; }

  .grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.3rem; }
  .tcard { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius-card); overflow: hidden; display: flex; flex-direction: column; transition: box-shadow 0.2s ease, transform 0.2s ease; }
  .tcard.is-hidden { display: none; }
  .tcard:hover { box-shadow: 0 18px 40px -22px rgba(20,20,30,0.28); transform: translateY(-3px); }
  .tcard__thumb { position: relative; display: block; width: 100%; aspect-ratio: 1280 / 820; overflow: hidden; background: #fff; border-bottom: 1px solid var(--line); cursor: pointer; }
  .tcard__thumb:focus-visible { outline: 2px solid var(--ink); outline-offset: -2px; }
  .tcard__body { padding: 0.9rem 1.1rem 1.1rem; display: flex; flex-direction: column; gap: 0.8rem; }
  .tcard__label { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); }
  .tcard__actions { display: flex; gap: 0.5rem; }
  .tcard__actions .btn { flex: 1; min-width: 0; font-size: 14px; padding: 0.42rem 0.7rem; }

  /* staggered entrance */
  @keyframes tcardRise { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: none; } }
  .tcard { animation: tcardRise 0.6s cubic-bezier(0.22, 1, 0.36, 1) backwards; animation-delay: var(--d, 0ms); }
  @media (prefers-reduced-motion: reduce) { .tcard { animation: none; } }

  @media (max-width: 1080px) { .grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 900px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .grid { grid-template-columns: 1fr; } }
</style>

<!-- Pagination buttons are created in JS (no scoped-CSS attribute), so style them globally. -->
<style is:global>
  .gpages { display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: 0.4rem; margin-top: 2.75rem; }
  .gpage { min-width: 2.5rem; height: 2.5rem; padding: 0 0.55rem; display: inline-flex; align-items: center; justify-content: center; border: 1px solid var(--line); background: #fff; border-radius: 11px; font-family: var(--font-body); font-size: 0.92rem; font-weight: 500; color: var(--text); cursor: pointer; transition: border-color 0.16s ease, background 0.16s ease, color 0.16s ease, box-shadow 0.16s ease, transform 0.12s ease; }
  .gpage:hover:not(:disabled):not(.is-active) { border-color: var(--line-strong); background: var(--surface-2); }
  .gpage:active:not(:disabled) { transform: translateY(1px); }
  .gpage.is-active { background: #5b5bd6; border-color: #5b5bd6; color: #fff; box-shadow: 0 8px 18px -7px rgba(91, 91, 214, 0.55); }
  .gpage:disabled { opacity: 0.35; cursor: default; }
  .gpage svg { width: 17px; height: 17px; }
  .gpage--nav { color: var(--muted); }
  .gpage--nav:hover:not(:disabled) { color: var(--text); }
  .gpage--dots { border: none; background: none; cursor: default; min-width: 1.25rem; color: var(--faint); font-weight: 600; letter-spacing: 0.05em; }
</style>

<script>
  const IFRAME_W = 1280;

  // Lazy-mount a preview iframe only when the card scrolls near the viewport.
  // The iframe is created in JS, so it gets NO scoped CSS — style it inline.
  const io = new IntersectionObserver((entries) => {
    for (const e of entries) {
      if (!e.isIntersecting) continue;
      const thumb = e.target as HTMLElement;
      io.unobserve(thumb);
      if (thumb.dataset.mounted) continue;
      thumb.dataset.mounted = '1';
      const iframe = document.createElement('iframe');
      iframe.src = thumb.dataset.preview || '';
      iframe.loading = 'lazy'; iframe.tabIndex = -1; iframe.title = '';
      iframe.setAttribute('scrolling', 'no');
      iframe.style.cssText = 'position:absolute;top:0;left:0;width:1280px;height:820px;border:0;transform-origin:top left;pointer-events:none;';
      thumb.appendChild(iframe);
      fit(thumb);
    }
  }, { rootMargin: '500px' });

  function fit(thumb: HTMLElement) {
    const iframe = thumb.querySelector('iframe');
    if (iframe) iframe.style.transform = `scale(${thumb.clientWidth / IFRAME_W})`;
  }

  async function copyText(text: string): Promise<boolean> {
    try { if (navigator.clipboard && window.isSecureContext) { await navigator.clipboard.writeText(text); return true; } } catch {}
    try {
      const ta = document.createElement('textarea');
      ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
      document.body.appendChild(ta); ta.focus(); ta.select();
      const ok = document.execCommand('copy'); ta.remove(); return ok;
    } catch { return false; }
  }

  // windowed page list: [0, …, cur-1, cur, cur+1, …, last]
  function pageWindow(cur: number, total: number): (number | '…')[] {
    const keep = new Set<number>([0, total - 1, cur - 1, cur, cur + 1]);
    const nums = [...keep].filter((p) => p >= 0 && p < total).sort((a, b) => a - b);
    const out: (number | '…')[] = [];
    let prev = -1;
    for (const p of nums) { if (p - prev > 1) out.push('…'); out.push(p); prev = p; }
    return out;
  }

  document.querySelectorAll<HTMLElement>('.gallery-root').forEach((root) => {
    const grid = root.querySelector<HTMLElement>('.grid');
    if (!grid) return;
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.tcard'));
    const pageSize = parseInt(grid.dataset.pageSize || '12', 10);
    const chips = Array.from(root.querySelectorAll<HTMLElement>('.chip'));
    const pagesEl = root.querySelector<HTMLElement>('.gpages');
    let filter = 'All';
    let page = 0;

    function renderPages(pageCount: number) {
      if (!pagesEl) return;
      pagesEl.innerHTML = '';
      if (pageCount <= 1) { pagesEl.hidden = true; return; }
      pagesEl.hidden = false;

      const chev = (d: string) => `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="${d}"/></svg>`;
      const mkBtn = (content: string, target: number, opts: { active?: boolean; disabled?: boolean; nav?: boolean; label?: string } = {}) => {
        const b = document.createElement('button');
        b.type = 'button';
        b.className = 'gpage' + (opts.active ? ' is-active' : '') + (opts.nav ? ' gpage--nav' : '');
        if (opts.nav) { b.innerHTML = content; b.setAttribute('aria-label', opts.label || ''); }
        else b.textContent = content;
        if (opts.active) b.setAttribute('aria-current', 'page');
        if (opts.disabled) b.disabled = true;
        else b.addEventListener('click', () => { page = target; apply(); root.scrollIntoView({ behavior: 'smooth', block: 'start' }); });
        return b;
      };

      pagesEl.appendChild(mkBtn(chev('M15 18l-6-6 6-6'), page - 1, { disabled: page === 0, nav: true, label: 'Previous page' }));
      for (const p of pageWindow(page, pageCount)) {
        if (p === '…') { const s = document.createElement('span'); s.className = 'gpage gpage--dots'; s.textContent = '…'; pagesEl.appendChild(s); }
        else pagesEl.appendChild(mkBtn(String(p + 1), p, { active: p === page }));
      }
      pagesEl.appendChild(mkBtn(chev('M9 18l6-6-6-6'), page + 1, { disabled: page === pageCount - 1, nav: true, label: 'Next page' }));
    }

    function apply() {
      const start = page * pageSize, end = start + pageSize;
      let matched = 0;
      cards.forEach((card) => {
        const isMatch = filter === 'All' || card.dataset.category === filter;
        let visible = false;
        if (isMatch) { visible = matched >= start && matched < end; matched++; }
        card.classList.toggle('is-hidden', !visible);
        if (visible) {
          const thumb = card.querySelector<HTMLElement>('.tcard__thumb');
          if (thumb && !thumb.dataset.mounted) io.observe(thumb);
        }
      });
      renderPages(Math.ceil(matched / pageSize));
    }

    chips.forEach((chip) => chip.addEventListener('click', () => {
      chips.forEach((c) => { c.classList.remove('chip--active'); c.setAttribute('aria-selected', 'false'); });
      chip.classList.add('chip--active'); chip.setAttribute('aria-selected', 'true');
      filter = chip.dataset.filter || 'All'; page = 0; apply();
    }));

    new ResizeObserver(() => cards.forEach((c) => { const t = c.querySelector<HTMLElement>('.tcard__thumb'); if (t?.dataset.mounted) fit(t); })).observe(grid);

    apply();
  });

  // Open preview in the same tab (thumbnail + Preview button)
  document.querySelectorAll<HTMLElement>('[data-preview]').forEach((el) => {
    const open = () => { const u = el.dataset.preview; if (u) window.location.href = u; };
    el.addEventListener('click', open);
    el.addEventListener('keydown', (ev) => { if (ev.key === 'Enter' || ev.key === ' ') { ev.preventDefault(); open(); } });
  });

  // Copy the block source on demand (fetched from /raw/<id>)
  document.querySelectorAll<HTMLButtonElement>('[data-copy-src]').forEach((btn) => {
    const labelEl = btn.querySelector<HTMLElement>('.btn__label') || btn;
    const original = labelEl.textContent || '';
    btn.addEventListener('click', async (e) => {
      e.preventDefault(); e.stopPropagation();
      let src = '';
      try { src = await (await fetch(btn.dataset.copySrc || '')).text(); } catch {}
      const ok = src ? await copyText(src) : false;
      btn.setAttribute('data-copied', ''); labelEl.textContent = ok ? 'Copied' : 'Press ⌘C';
      setTimeout(() => { btn.removeAttribute('data-copied'); labelEl.textContent = original; }, 1600);
    });
  });
</script>
