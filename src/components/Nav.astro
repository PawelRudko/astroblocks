---
// Nav — shared navigation. variant="overlay" (transparent over the hero on /) or "solid" (white bar on subpages).
import Brand from './Brand.astro';
interface Props { variant?: 'overlay' | 'solid' }
const { variant = 'overlay' } = Astro.props;
---
<header class:list={['nav', `nav--${variant}`]}>
  <div class="wrap nav__inner">
    <Brand href="/" />
    <nav class="nav__links" aria-label="Main">
      <a href="/blocks">Blocks</a>
    </nav>
    <a class="btn btn--sm btn--primary" href="https://github.com/PawelRudko/astroblocks" target="_blank" rel="noopener">
      <svg class="btn__ico" viewBox="0 0 16 16" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path></svg>
      Get it on GitHub
    </a>
  </div>
</header>

<style>
  .nav { z-index: 50; }
  .nav--overlay { position: absolute; top: 0; left: 0; right: 0; }
  .nav--solid { position: sticky; top: 0; background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(12px); border-bottom: 1px solid var(--line); }
  .nav__inner { display: flex; align-items: center; gap: 1.5rem; height: 66px; }
  .nav__links { display: flex; gap: 1.8rem; margin-left: auto; font-size: 0.92rem; font-weight: 500; color: var(--muted); }
  .nav__links a:hover { color: var(--text); }
  @media (max-width: 900px) { .nav__links { display: none; } }
</style>
