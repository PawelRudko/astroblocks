---
// Kanciaste pastelowe pole w stylu Keystatic — WŁASNA grafika (nie ich assety).
// Podmienialne: zmień kolory w :root (--geo-*) albo poligony niżej.
interface Props { variant?: 'hero' | 'footer'; }
const { variant = 'hero' } = Astro.props;
---
{variant === 'hero' && (
  <svg class="geo geo--hero" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 1440 1024" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <g clip-path="url(#hero-img-a)">
      <path stroke="url(#hero-img-b)" stroke-width="426" d="M977-150 205 622v413"></path>
      <path stroke="url(#hero-img-c)" stroke-width="426" d="M1580-153 631 796v239"></path>
      <path stroke="url(#hero-img-d)" stroke-width="426" d="m869 256 464 464v315"></path>
      <path stroke="url(#hero-img-e)" stroke-linejoin="round" stroke-width="426" d="m721 707 747-747" opacity=".4"></path>
    </g>
    <defs>
      <linearGradient id="hero-img-b" x1="565" x2="205" y1="197.8" y2="624.4" gradientUnits="userSpaceOnUse"><stop stop-color="#D3C6F9"></stop><stop offset="1" stop-color="#FAC6BD"></stop></linearGradient>
      <linearGradient id="hero-img-c" x1="911" x2="631" y1="537.8" y2="804.4" gradientUnits="userSpaceOnUse"><stop stop-color="#FED888"></stop><stop offset="1" stop-color="#BEE3BF"></stop></linearGradient>
      <linearGradient id="hero-img-d" x1="920.1" x2="1333.4" y1="306.7" y2="728.9" gradientUnits="userSpaceOnUse"><stop stop-color="#D3C6F9"></stop><stop offset="1" stop-color="#B4E0EA"></stop></linearGradient>
      <linearGradient id="hero-img-e" x1="1001.4" x2="721.4" y1="448.9" y2="715.6" gradientUnits="userSpaceOnUse"><stop stop-color="#FED888"></stop><stop offset="1" stop-color="#BEE3BF"></stop></linearGradient>
      <clipPath id="hero-img-a"><path fill="#fff" d="M0 0h1440v1024H0z"></path></clipPath>
    </defs>
  </svg>
)}
{variant === 'footer' && (
  <svg class="geo geo--footer" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 324 184" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <path stroke="url(#pattern6-a)" stroke-linejoin="round" stroke-width="96" d="m-33-153 458 458"></path>
    <path stroke="url(#pattern6-b)" stroke-width="96" d="M-40-24 77 93h136l97 98"></path>
    <path stroke="url(#pattern6-c)" stroke-linejoin="round" stroke-width="96" d="m81-38 229 229" opacity=".4"></path>
    <defs>
      <linearGradient id="pattern6-a" x1="-33.2" x2="265.6" y1="-153" y2="145.7" gradientUnits="userSpaceOnUse"><stop stop-color="#AADEE6"></stop><stop offset="1" stop-color="#F3C6E2"></stop></linearGradient>
      <linearGradient id="pattern6-b" x1="71.5" x2="272.3" y1="87.4" y2="288.2" gradientUnits="userSpaceOnUse"><stop stop-color="#FFF8BB"></stop><stop offset="1" stop-color="#D7CFF9"></stop></linearGradient>
      <linearGradient id="pattern6-c" x1="81.4" x2="230.8" y1="-38.4" y2="110.9" gradientUnits="userSpaceOnUse"><stop stop-color="#AADEE6"></stop><stop offset="1" stop-color="#F3C6E2"></stop></linearGradient>
    </defs>
  </svg>
)}

<style>
  .geo { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; }
  .geo--hero { opacity: 1; filter: saturate(1.3); transform: scaleX(-1); }
  .geo--footer { opacity: 1; filter: saturate(1.3); }
</style>
