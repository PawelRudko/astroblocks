---
// HeroSplit — dwukolumnowy hero (treść lewo, obraz prawo) w czystym stylu jak HeroCentered.
// System nagłówków + 3 przyciski + lekka animacja wejścia. Edytuj rozmową (patrz AGENTS.md).
interface Cta { label: string; href: string }
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  primary?: Cta;
  secondary?: Cta;
  link?: Cta;
  image?: string;
  imageAlt?: string;
  bg?: 'white' | 'gray';
}
const {
  eyebrow,
  title,
  subtitle,
  primary,
  secondary,
  link,
  image = '/placeholder-landscape.svg',
  imageAlt = '',
  bg = 'white',
} = Astro.props;
---

<section class:list={['hs', `hs--${bg}`]}>
  <div class="hs__inner">
    <div class="hs__content">
      {eyebrow && <span class="eyebrow hs__anim" style="--d:0ms">{eyebrow}</span>}
      <h1 class="hs__title hs__anim" style="--d:80ms">{title}</h1>
      {subtitle && <p class="hs__subtitle hs__anim" style="--d:160ms">{subtitle}</p>}
      {(primary || secondary || link) && (
        <div class="hs__actions hs__anim" style="--d:240ms">
          {primary && <a class="btn btn--primary" href={primary.href}>{primary.label}</a>}
          {secondary && <a class="btn btn--secondary" href={secondary.href}>{secondary.label}</a>}
          {link && (
            <a class="btn btn--link" href={link.href}>
              {link.label}
              <span class="hs__arrow" aria-hidden="true">→</span>
            </a>
          )}
        </div>
      )}
    </div>

    <figure class="hs__media hs__anim" style="--d:200ms">
      <img src={image} alt={imageAlt} loading="lazy" />
    </figure>
  </div>
</section>

<style>
  .hs { padding: clamp(3rem, 7vw, 6rem) clamp(1.25rem, 4vw, 2.5rem); }
  .hs--white { background: #ffffff; }
  .hs--gray { background: #f5f4f2; }

  .hs__inner {
    max-width: 1200px; margin-inline: auto;
    display: grid; grid-template-columns: 1fr 1.05fr;
    gap: clamp(2rem, 5vw, 4.5rem); align-items: center;
  }
  .hs__content { max-width: 32rem; }
  .hs__title { margin: 0.9rem 0 0; }
  .hs__subtitle { margin: 1.1rem 0 0; font-size: 1.15rem; line-height: 1.5; color: rgba(33, 32, 28, 0.7); }
  .hs__actions { display: flex; flex-wrap: wrap; align-items: center; gap: 0.7rem; margin-top: 1.9rem; }
  .hs__arrow { transition: transform 0.18s ease; }
  .btn--link:hover .hs__arrow { transform: translateX(3px); }

  .hs__media img {
    width: 100%; aspect-ratio: 4 / 3; object-fit: cover;
    border-radius: 16px; border: 1px solid var(--line);
    box-shadow: 0 40px 80px -40px rgba(20, 20, 30, 0.28);
  }

  /* lekka animacja wejścia — staggered */
  @keyframes hsRise { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: none; } }
  @keyframes hsMedia { from { opacity: 0; transform: translateX(26px) scale(0.99); } to { opacity: 1; transform: none; } }
  .hs__anim { opacity: 0; animation: hsRise 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards; animation-delay: var(--d, 0ms); }
  .hs__media.hs__anim { animation-name: hsMedia; }

  @media (prefers-reduced-motion: reduce) {
    .hs__anim { opacity: 1 !important; transform: none !important; animation: none !important; }
  }

  @media (max-width: 820px) {
    .hs__inner { grid-template-columns: 1fr; gap: 2rem; }
    .hs__content { max-width: none; }
    .hs__media { order: -1; }
    .hs__media img { aspect-ratio: 16 / 9; }
  }
  @media (max-width: 600px) {
    .hs__actions { width: 100%; }
    .hs__actions .btn { flex: 1 1 auto; }
    .hs__actions .btn--link { flex-basis: 100%; }
  }
</style>
