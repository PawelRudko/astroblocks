---
// Footer — editorial footer: brand + tagline on top, link columns (Product / Company / Contact /
// Follow Us) below, and a bottom bar with copyright + credit. Compact padding. Same system.
// Edit by chat (see AGENTS.md).
interface Link { label: string; href: string }
interface Column { heading: string; links: Link[] }
interface Social { type: 'twitter' | 'linkedin' | 'instagram' | 'dribbble'; href: string }
interface Props {
  brand?: string;
  tagline?: string;
  columns?: Column[];
  contact?: { heading?: string; email?: Link; phone?: string };
  socials?: { heading?: string; items: Social[] };
  copyright?: string;
  credit?: { label: string; linkLabel: string; href: string } | null;
  bg?: 'white' | 'gray' | 'dark';
}
const {
  brand = 'Astroblock ©',
  tagline = 'From first sketch to final interior, every detail is shaped to feel natural, calm and built to last.',
  columns = [
    { heading: 'Product', links: [
      { label: 'Services', href: '#' },
      { label: 'Get a Quote', href: '#' },
      { label: 'Contact', href: '#' },
    ] },
    { heading: 'Company', links: [
      { label: 'About Us', href: '#' },
      { label: 'Careers', href: '#' },
      { label: 'Latest Updates', href: '#' },
    ] },
  ],
  contact = { heading: 'Contact', email: { label: 'hello@studio.com', href: 'mailto:hello@studio.com' }, phone: '+39 02 1234 567' },
  socials = { heading: 'Follow Us', items: [
    { type: 'linkedin', href: '#' },
    { type: 'twitter', href: '#' },
    { type: 'instagram', href: '#' },
  ] },
  copyright = 'Astroblock © 2026',
  credit = { label: 'Built with', linkLabel: 'Astroblocks', href: '#' },
  bg = 'white',
} = Astro.props;

// social line icons (fill), keyed by type
const social = {
