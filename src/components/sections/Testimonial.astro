---
// Testimonial — centered quote slider with avatar, name/role, prev/next arrows and dots.
// Fade between slides, keyboard + aria wired. No dependencies, on-system. Edit by chat (AGENTS.md).
interface Item { quote: string; name: string; role?: string; avatar?: string }
interface Props { items: Item[]; bg?: 'white' | 'gray' }
const { items, bg = 'white' } = Astro.props;
const ph = '/placeholder-landscape.svg';
---

<section class:list={['tst', `tst--${bg}`]}>
  <div class="tst__wrap">
    <button class="tst__arrow tst__arrow--prev" type="button" aria-label="Previous testimonial">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7" /></svg>
    </button>

    <div class="tst__viewport">
      {items.map((t, i) => (
        <figure class="tst__slide" aria-hidden={i === 0 ? 'false' : 'true'}>
          <blockquote class="tst__quote">“{t.quote}”</blockquote>
          <img class="tst__avatar" src={t.avatar || ph} alt="" loading="lazy" />
          <figcaption class="tst__person">
            <span class="tst__name">{t.name}</span>
            {t.role && <span class="tst__role">{t.role}</span>}
          </figcaption>
        </figure>
      ))}
    </div>

    <button class="tst__arrow tst__arrow--next" type="button" aria-label="Next testimonial">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
    </button>

    <div class="tst__dots" role="tablist" aria-label="Choose testimonial">
      {items.map((_, i) => (
        <button class="tst__dot" type="button" role="tab" aria-current={i === 0 ? 'true' : 'false'} aria-label={`Go to testimonial ${i + 1}`}></button>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('.tst').forEach((root) => {
    const slides = Array.from(root.querySelectorAll<HTMLElement>('.tst__slide'));
    const dots = Array.from(root.querySelectorAll<HTMLElement>('.tst__dot'));
    let idx = 0;
    const show = (n: number) => {
      idx = (n + slides.length) % slides.length;
      slides.forEach((s, i) => s.setAttribute('aria-hidden', i === idx ? 'false' : 'true'));
      dots.forEach((d, i) => d.setAttribute('aria-current', i === idx ? 'true' : 'false'));
    };
    root.querySelector('.tst__arrow--prev')?.addEventListener('click', () => show(idx - 1));
    root.querySelector('.tst__arrow--next')?.addEventListener('click', () => show(idx + 1));
    dots.forEach((d, i) => d.addEventListener('click', () => show(i)));
  });
</script>

<style>
  .tst { padding: clamp(3rem, 7vw, 6rem) 0; }
  .tst--white { background: #ffffff; }
  .tst--gray { background: #f5f4f2; }
  .tst__wrap { position: relative; max-width: 820px; margin-inline: auto; padding-inline: clamp(3.75rem, 10vw, 6rem); }

  .tst__viewport { display: grid; }
  .tst__slide {
    grid-area: 1 / 1; display: flex; flex-direction: column; align-items: center; text-align: center;
    opacity: 0; visibility: hidden; transition: opacity 0.4s ease;
  }
  .tst__slide[aria-hidden='false'] { opacity: 1; visibility: visible; }

  .tst__quote { font-family: var(--font-display); font-size: clamp(1.2rem, 2.6vw, 1.6rem); font-weight: 500; line-height: 1.4; letter-spacing: -0.01em; color: var(--text); max-width: 40ch; }
  .tst__avatar { width: 56px; height: 56px; border-radius: 50%; object-fit: cover; background: #ececea; margin-top: clamp(1.75rem, 4vw, 2.5rem); }
  .tst__person { display: flex; flex-direction: column; gap: 0.15rem; margin-top: 0.9rem; }
  .tst__name { font-weight: 600; color: var(--text); }
  .tst__role { font-size: 0.9rem; color: var(--muted); }

  /* Arrows (vertically centered on the sides) */
  .tst__arrow {
    position: absolute; top: 50%; transform: translateY(-50%);
    width: 46px; height: 46px; display: grid; place-items: center;
    background: #fff; border: 1px solid var(--line-strong); border-radius: 50%; cursor: pointer; color: var(--text);
    transition: color 0.18s ease, border-color 0.18s ease;
  }
  .tst__arrow svg { width: 18px; height: 18px; }
  .tst__arrow:hover { color: #5b5bd6; border-color: #5b5bd6; }
  .tst__arrow--prev { left: 0; }
  .tst__arrow--next { right: 0; }

  .tst__dots { display: flex; justify-content: center; gap: 0.5rem; margin-top: clamp(1.75rem, 4vw, 2.5rem); }
  .tst__dot { width: 9px; height: 9px; padding: 0; border: none; border-radius: 50%; background: var(--line-strong); cursor: pointer; transition: background 0.18s ease, transform 0.18s ease; }
  .tst__dot[aria-current='true'] { background: #5b5bd6; transform: scale(1.15); }

  @media (max-width: 600px) {
    .tst__wrap { padding-inline: 0; }
    .tst__arrow { position: static; transform: none; }
    .tst__viewport { order: -1; }
    .tst__wrap { display: grid; grid-template-columns: auto 1fr auto; grid-template-areas: 'q q q' 'prev dots next'; align-items: center; gap: 1rem; }
    .tst__viewport { grid-area: q; }
    .tst__arrow--prev { grid-area: prev; }
    .tst__arrow--next { grid-area: next; }
    .tst__dots { grid-area: dots; margin-top: 0; }
  }

  @media (prefers-reduced-motion: reduce) { .tst__slide { transition: none; } }
</style>
