---
// FeatureStackCards — sticky left content + a column of cards that stack on top of each other on scroll.
// Pure CSS (position: sticky, per-card offset). On-system, responsive (stacking off on mobile). Edit by chat (AGENTS.md).
interface Btn { label: string; href?: string }
interface Card { title: string; text?: string }
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  primary?: Btn;
  secondary?: Btn;
  cards: Card[];
  bg?: 'white' | 'gray';
}
const { eyebrow, title, subtitle, primary, secondary, cards, bg = 'white' } = Astro.props;
---

<section class:list={['fsc', `fsc--${bg}`]}>
  <div class="fsc__wrap">
    <div class="fsc__content">
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h2 class="fsc__title">{title}</h2>
      {subtitle && <p class="fsc__lead">{subtitle}</p>}
      {(primary || secondary) && (
        <div class="fsc__cta">
          {primary && <a class="btn btn--secondary" href={primary.href || '#'}>{primary.label}</a>}
          {secondary && <a class="btn btn--link" href={secondary.href || '#'}>{secondary.label} <span aria-hidden="true">→</span></a>}
        </div>
      )}
    </div>

    <div class="fsc__cards">
      {cards.map((c, i) => (
        <article class="fsc__card" style={`--i:${i}`}>
          <svg class="fsc__ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
            <path d="M3.27 6.96 12 12.01l8.73-5.05" /><path d="M12 22.08V12" />
          </svg>
          <h3 class="fsc__card-title">{c.title}</h3>
          {c.text && <p class="fsc__card-text">{c.text}</p>}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .fsc { padding: clamp(3rem, 7vw, 6rem) 0; }
  .fsc--white { background: #ffffff; }
  .fsc--gray { background: #f5f4f2; }
  .fsc__wrap { max-width: 1200px; margin-inline: auto; padding-inline: clamp(1.25rem, 4vw, 2.5rem); display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }

  .fsc__content { position: sticky; top: clamp(2rem, 14vh, 6rem); }
  .fsc__title { margin-top: 0.8rem; }
  .fsc__lead { margin-top: 1rem; max-width: 44ch; color: rgba(33, 32, 28, 0.66); font-size: 15px; line-height: 1.6; }
  .fsc__cta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.7rem; margin-top: 1.8rem; }

  /* moderate spacing = enough scroll travel to pile, but cards stay close for a tidy initial view */
  .fsc__cards { display: flex; flex-direction: column; gap: clamp(1.5rem, 11vh, 5rem); padding-bottom: 22vh; }
  .fsc__card {
    position: sticky; top: calc(clamp(2rem, 14vh, 6rem) + var(--i) * 14px);
    background: #fff; border: 1px solid var(--line); border-radius: var(--radius-card);
    padding: clamp(1.5rem, 3vw, 2.25rem); box-shadow: 0 14px 40px -22px rgba(20, 20, 30, 0.4);
  }
  .fsc__ico { width: 34px; height: 34px; color: var(--text); }
  .fsc__card-title { margin-top: 1.1rem; font-size: 1.25rem; }
  .fsc__card-text { margin-top: 0.6rem; color: rgba(33, 32, 28, 0.66); font-size: 15px; line-height: 1.6; }

  @media (max-width: 900px) {
    .fsc__wrap { grid-template-columns: 1fr; gap: clamp(1.75rem, 5vw, 2.5rem); }
    .fsc__content, .fsc__card { position: static; }
  }
</style>
