---
// Footer02 — full-bleed image on top, then a newsletter block (heading + form + socials) on the left
// with Product / Company link columns on the right, and a 3-part bottom bar. Same system.
// Edit by chat (see AGENTS.md).
interface Link { label: string; href: string }
interface Column { heading: string; links: Link[] }
interface Social { type: 'twitter' | 'linkedin' | 'instagram' | 'google' | 'youtube' | 'facebook'; href: string }
interface Props {
  image?: string;
  imageAlt?: string;
  newsletterHeading?: string;
  placeholder?: string;
  buttonLabel?: string;
  socialsHeading?: string;
  socials?: Social[];
  columns?: Column[];
  credit?: { label: string; linkLabel: string; href: string } | null;
  founded?: string;
  copyright?: string;
  bg?: 'white' | 'gray';
}
const {
  image = '/placeholder-landscape.svg',
  imageAlt = '',
  newsletterHeading = 'Stay updated',
  placeholder = 'Email',
  buttonLabel = 'Subscribe',
  socialsHeading = 'Follow Us',
  socials = [
    { type: 'linkedin', href: '#' },
    { type: 'twitter', href: '#' },
    { type: 'google', href: '#' },
  ],
  columns = [
    { heading: 'Product', links: [
      { label: 'Services', href: '#' },
      { label: 'Get a Quote', href: '#' },
      { label: 'Contact', href: '#' },
    ] },
    { heading: 'Company', links: [
      { label: 'About Us', href: '#' },
      { label: 'Careers', href: '#' },
      { label: 'Blog', href: '#' },
    ] },
  ],
  credit = { label: 'Built with', linkLabel: 'Astroblocks', href: '#' },
  founded = 'Est. 2002',
  copyright = 'Astroblock © 2026',
  bg = 'white',
} = Astro.props;

const social = {
  twitter: 'M22 5.9a8.2 8.2 0 0 1-2.4.66A4.1 4.1 0 0 0 21.4 4.3a8.3 8.3 0 0 1-2.6 1A4.15 4.15 0 0 0 11.5 8.1a11.8 11.8 0 0 1-8.5-4.3 4.15 4.15 0 0 0 1.3 5.5A4.1 4.1 0 0 1 2.4 8.8v.05a4.15 4.15 0 0 0 3.3 4.07 4.2 4.2 0 0 1-1.87.07 4.15 4.15 0 0 0 3.87 2.88A8.3 8.3 0 0 1 2 17.6a11.75 11.75 0 0 0 6.35 1.86c7.62 0 11.79-6.31 11.79-11.79l-.01-.54A8.4 8.4 0 0 0 22 5.9z',
  linkedin: 'M6.94 5a1.94 1.94 0 1 1-3.88 0 1.94 1.94 0 0 1 3.88 0zM3.3 8.4h3.28V21H3.3zM9.1 8.4h3.14v1.72h.05c.44-.83 1.5-1.7 3.1-1.7 3.32 0 3.93 2.18 3.93 5.02V21h-3.28v-4.86c0-1.16-.02-2.65-1.62-2.65-1.62 0-1.87 1.26-1.87 2.57V21H9.1z',
  instagram: 'M12 7.4a4.6 4.6 0 1 0 0 9.2 4.6 4.6 0 0 0 0-9.2zm0 7.6a3 3 0 1 1 0-6 3 3 0 0 1 0 6zm4.8-7.78a1.07 1.07 0 1 1-2.14 0 1.07 1.07 0 0 1 2.14 0zM20.9 8.85c-.05-1.45-.38-2.73-1.44-3.79S17.05 3.66 15.6 3.6c-1.5-.08-5.98-.08-7.48 0-1.44.05-2.72.38-3.79 1.44S3.11 6.95 3.05 8.4c-.08 1.5-.08 5.98 0 7.48.05 1.45.38 2.73 1.44 3.79s2.34 1.39 3.79 1.45c1.5.08 5.98.08 7.48 0 1.45-.05 2.73-.38 3.79-1.45s1.39-2.34 1.45-3.79c.08-1.5.08-5.97 0-7.47z',
  google: 'M12 11v2.9h4.05c-.17 1.05-1.2 3.08-4.05 3.08A4.48 4.48 0 1 1 12 7.5c1.28 0 2.14.55 2.63 1.02l1.8-1.73C15.28 5.7 13.8 5 12 5a7 7 0 1 0 0 14c4.04 0 6.7-2.84 6.7-6.84 0-.46-.05-.81-.11-1.16H12z',
  youtube: 'M23 8.2a3 3 0 0 0-2.1-2.1C19 5.6 12 5.6 12 5.6s-7 0-8.9.5A3 3 0 0 0 1 8.2 31 31 0 0 0 .6 12 31 31 0 0 0 1 15.8a3 3 0 0 0 2.1 2.1c1.9.5 8.9.5 8.9.5s7 0 8.9-.5a3 3 0 0 0 2.1-2.1c.3-1.2.4-2.5.4-3.8s-.1-2.6-.4-3.8zM9.75 15.02V8.98L15 12z',
  facebook: 'M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z',
};
---

<footer class:list={['ft2', `ft2--${bg}`]}>
  <figure class="ft2__media">
    <img src={image} alt={imageAlt} loading="lazy" />
  </figure>

  <div class="ft2__wrap">
    <div class="ft2__body">
      <div class="ft2__lead">
        <h2 class="ft2__title">{newsletterHeading}</h2>
        <form class="ft2__form" onsubmit="return false">
          <input class="ft2__input" type="email" placeholder={placeholder} aria-label={placeholder} />
          <button class="btn btn--secondary" type="submit">{buttonLabel}</button>
        </form>
        {socials.length > 0 && (
          <div class="ft2__follow">
            <span class="ft2__h">{socialsHeading}</span>
            <div class="ft2__socials">
              {socials.map((s) => (
                <a class="ft2__social" href={s.href} aria-label={s.type} target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d={social[s.type]} /></svg>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

      {columns.map((col) => (
        <div class="ft2__col">
          <span class="ft2__h">{col.heading}</span>
          <ul class="ft2__list">
            {col.links.map((l) => <li><a class="ft2__link" href={l.href}>{l.label}</a></li>)}
          </ul>
        </div>
      ))}
    </div>

    <div class="ft2__bar">
      {credit ? <span class="ft2__bar-item">{credit.label} <a class="ft2__credit-link" href={credit.href}>{credit.linkLabel}</a></span> : <span></span>}
      <span class="ft2__bar-item ft2__bar-item--mid">{founded}</span>
      <span class="ft2__bar-item ft2__bar-item--end">{copyright}</span>
    </div>
  </div>
</footer>

<style>
  .ft2 { font-family: var(--font-body); color: var(--text); }
  .ft2--white { background: #ffffff; }
  .ft2--gray { background: #f5f4f2; }
  .ft2 a { color: inherit; text-decoration: none; }

  .ft2__media { margin: 0; }
  .ft2__media img { display: block; width: 100%; height: clamp(240px, 34vw, 440px); object-fit: cover; }

  .ft2__wrap { max-width: var(--maxw, 1440px); margin-inline: auto; padding: clamp(2.5rem, 5vw, 4rem) clamp(1.25rem, 4vw, 2.5rem) clamp(1.75rem, 3vw, 2.5rem); }

  .ft2__body { display: grid; grid-template-columns: 1.5fr 1fr 1fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
  .ft2__lead { max-width: 30rem; }
  .ft2__title { margin: 0 0 1.4rem; font-size: clamp(1.5rem, 2.5vw, 2rem); }

  .ft2__form { display: flex; gap: 0.6rem; }
  .ft2__input { flex: 1; min-width: 0; border: 1px solid var(--line-strong); border-radius: var(--radius-btn); padding: 0.6rem 0.9rem; font: inherit; font-size: 0.95rem; color: var(--text); background: #fff; }
  .ft2__input::placeholder { color: var(--faint); }
  .ft2__input:focus { outline: none; border-color: #5b5bd6; box-shadow: 0 0 0 3px rgba(91, 91, 214, 0.12); }
  .ft2__form .btn { flex: none; }

  .ft2__follow { margin-top: clamp(1.75rem, 4vw, 2.75rem); }
  .ft2__h { display: block; font-size: 0.95rem; font-weight: 500; color: var(--faint); margin-bottom: 1rem; }
  .ft2__socials { display: flex; align-items: center; gap: 1rem; }
  .ft2__social { display: inline-flex; transition: color 0.18s ease, transform 0.18s ease; }
  .ft2__social:hover { color: #5b5bd6; transform: translateY(-2px); }

  .ft2__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.65rem; }
  .ft2__link { font-size: 1rem; font-weight: 500; transition: color 0.18s ease; }
  .ft2__link:hover { color: #5b5bd6; }

  .ft2__bar { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; align-items: center; margin-top: clamp(2.5rem, 6vw, 4rem); padding-top: clamp(1.25rem, 2.5vw, 1.75rem); border-top: 1px solid var(--line); }
  .ft2__bar-item { font-size: 0.95rem; font-weight: 600; }
  .ft2__bar-item--mid { text-align: center; }
  .ft2__bar-item--end { text-align: right; }
  .ft2__credit-link { text-decoration: underline; text-underline-offset: 3px; }
  .ft2__credit-link:hover { color: #5b5bd6; }

  @media (max-width: 860px) {
    .ft2__body { grid-template-columns: 1fr 1fr; }
    .ft2__lead { grid-column: 1 / -1; max-width: none; }
  }
  @media (max-width: 520px) {
    .ft2__body { grid-template-columns: 1fr; }
    .ft2__bar { grid-template-columns: 1fr; gap: 0.5rem; }
    .ft2__bar-item--mid, .ft2__bar-item--end { text-align: left; }
  }
</style>
