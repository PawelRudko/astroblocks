---
// HeroEditorial — editorial hero with an integrated responsive nav (brand + links + socials),
// a right-aligned oversized heading with a muted tail, a meta row (email / location / est.)
// and a full-bleed image below. Same clean system. Edit by chat (see AGENTS.md).
interface Link { label: string; href: string }
interface Social { type: 'twitter' | 'linkedin' | 'instagram'; href: string }
interface Props {
  brand?: string;
  nav?: Link[];
  socials?: Social[];
  eyebrow?: string;
  title: string;
  titleMuted?: string;
  email?: Link;
  location?: string;
  founded?: string;
  image?: string;
  imageAlt?: string;
  bg?: 'white' | 'gray';
}
const {
  brand = 'Felt Layouts©',
  nav = [
    { label: 'Projects', href: '#' },
    { label: 'Services', href: '#' },
    { label: 'Contact', href: '#' },
  ],
  socials = [
    { type: 'twitter', href: '#' },
    { type: 'linkedin', href: '#' },
  ],
  eyebrow = 'Felt',
  title = 'Custom-built homes shaped by light, nature, and simplicity, inspired by',
  titleMuted = 'Scandinavian simplicity',
  email = { label: 'hello@thecompany.com', href: 'mailto:hello@thecompany.com' },
  location = 'Helsinki, Finland',
  founded = 'Est 2002',
  image = '/placeholder-landscape.svg',
  imageAlt = '',
  bg = 'white',
} = Astro.props;

// social line icons (stroke/fill), keyed by type
const social = {
  twitter: 'M22 5.9a8.2 8.2 0 0 1-2.4.66A4.1 4.1 0 0 0 21.4 4.3a8.3 8.3 0 0 1-2.6 1A4.15 4.15 0 0 0 11.5 8.1a11.8 11.8 0 0 1-8.5-4.3 4.15 4.15 0 0 0 1.3 5.5A4.1 4.1 0 0 1 2.4 8.8v.05a4.15 4.15 0 0 0 3.3 4.07 4.2 4.2 0 0 1-1.87.07 4.15 4.15 0 0 0 3.87 2.88A8.3 8.3 0 0 1 2 17.6a11.75 11.75 0 0 0 6.35 1.86c7.62 0 11.79-6.31 11.79-11.79l-.01-.54A8.4 8.4 0 0 0 22 5.9z',
  linkedin: 'M6.94 5a1.94 1.94 0 1 1-3.88 0 1.94 1.94 0 0 1 3.88 0zM3.3 8.4h3.28V21H3.3zM9.1 8.4h3.14v1.72h.05c.44-.83 1.5-1.7 3.1-1.7 3.32 0 3.93 2.18 3.93 5.02V21h-3.28v-4.86c0-1.16-.02-2.65-1.62-2.65-1.62 0-1.87 1.26-1.87 2.57V21H9.1z',
  instagram: 'M12 7.4a4.6 4.6 0 1 0 0 9.2 4.6 4.6 0 0 0 0-9.2zm0 7.6a3 3 0 1 1 0-6 3 3 0 0 1 0 6zm4.8-7.78a1.07 1.07 0 1 1-2.14 0 1.07 1.07 0 0 1 2.14 0zM20.9 8.85c-.05-1.45-.38-2.73-1.44-3.79S17.05 3.66 15.6 3.6c-1.5-.08-5.98-.08-7.48 0-1.44.05-2.72.38-3.79 1.44S3.11 6.95 3.05 8.4c-.08 1.5-.08 5.98 0 7.48.05 1.45.38 2.73 1.44 3.79s2.34 1.39 3.79 1.45c1.5.08 5.98.08 7.48 0 1.45-.05 2.73-.38 3.79-1.45s1.39-2.34 1.45-3.79c.08-1.5.08-5.97 0-7.47z',
};
---

<section class:list={['he', `he--${bg}`]}>
  <div class="he__frame">
    <header class="he__nav he__anim" style="--d:0ms">
      <a class="he__brand" href="#">{brand}</a>

      <nav class="he__links" aria-label="Primary">
        {nav.map((l) => <a class="he__link" href={l.href}>{l.label}</a>)}
        {socials.length > 0 && (
          <span class="he__socials">
            {socials.map((s) => (
              <a class="he__social" href={s.href} aria-label={s.type} target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true"><path d={social[s.type]} /></svg>
              </a>
            ))}
          </span>
        )}
      </nav>

      <button class="he__burger" type="button" data-he-burger aria-label="Open menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" /></svg>
      </button>
    </header>

    <!-- mobile menu -->
    <div class="he__mobile" data-he-mobile hidden>
      {nav.map((l) => <a href={l.href}>{l.label}</a>)}
      {socials.length > 0 && (
        <span class="he__m-socials">
          {socials.map((s) => (
            <a href={s.href} aria-label={s.type} target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d={social[s.type]} /></svg>
            </a>
          ))}
        </span>
      )}
    </div>

    <div class="he__content">
      {eyebrow && <span class="eyebrow he__eyebrow he__anim" style="--d:80ms">{eyebrow}</span>}
      <h1 class="he__title he__anim" style="--d:140ms">
        {title}{titleMuted && <> <span class="he__muted">{titleMuted}</span></>}
      </h1>
    </div>

    <div class="he__meta he__anim" style="--d:220ms">
      {email && (
        <a class="he__email" href={email.href}>
          {email.label}<span class="he__arrow" aria-hidden="true">→</span>
        </a>
      )}
      <div class="he__facts">
        {location && <span class="he__fact">{location}</span>}
        {founded && <span class="he__fact">{founded}</span>}
      </div>
    </div>
  </div>

  <figure class="he__media he__anim" style="--d:300ms">
    <img src={image} alt={imageAlt} loading="lazy" />
  </figure>
</section>

<style>
  .he { font-family: var(--font-body); color: var(--text); }
  .he--white { background: #ffffff; }
  .he--gray { background: #f5f4f2; }
  .he a { color: inherit; text-decoration: none; }

  .he__frame { max-width: 1200px; margin-inline: auto; padding: 0 clamp(1.25rem, 4vw, 2.5rem); }

  /* nav */
  .he__nav { height: 72px; display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; }
  .he__brand { font-weight: 600; font-size: 0.95rem; letter-spacing: -0.01em; }
  .he__links { display: flex; align-items: center; gap: 1.4rem; }
  .he__link { font-size: 0.92rem; font-weight: 500; transition: color 0.18s ease; }
  .he__link:hover { color: #5b5bd6; }
  .he__socials { display: inline-flex; align-items: center; gap: 0.9rem; margin-left: 0.5rem; }
  .he__social { display: inline-flex; color: var(--text); transition: color 0.18s ease; }
  .he__social:hover { color: #5b5bd6; }
  .he__burger { display: none; background: none; border: 0; color: var(--text); cursor: pointer; padding: 6px; }

  /* mobile menu */
  .he__mobile { display: none; padding: 0.5rem 0 1.25rem; border-top: 1px solid var(--line); }
  .he__mobile a { display: block; padding: 0.6rem 0; font-size: 1rem; font-weight: 500; }
  .he__m-socials { display: flex; gap: 1.1rem; padding-top: 0.8rem; }

  /* content — right-aligned oversized heading */
  .he__content { display: grid; grid-template-columns: 1fr 1.05fr; padding: clamp(3rem, 8vw, 6.5rem) 0 clamp(2rem, 5vw, 3.5rem); }
  .he__content > * { grid-column: 2; }
  .he__eyebrow { margin-bottom: 1.1rem; }
  .he__title { margin: 0; font-size: clamp(1.75rem, 3.4vw, 2.65rem); line-height: 1.18; letter-spacing: -0.02em; max-width: 20ch; }
  .he__muted { color: var(--faint); }

  /* meta row */
  .he__meta { display: grid; grid-template-columns: 1fr 1.05fr; align-items: baseline; gap: 1.5rem; padding-bottom: clamp(2rem, 5vw, 3.25rem); }
  .he__email { grid-column: 1; justify-self: center; display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.95rem; font-weight: 500; transition: color 0.18s ease; }
  .he__email:hover { color: #5b5bd6; }
  .he__arrow { transition: transform 0.18s ease; }
  .he__email:hover .he__arrow { transform: translateX(3px); }
  .he__facts { grid-column: 2; display: flex; gap: clamp(2.5rem, 8vw, 6rem); }
  .he__fact { font-size: 0.95rem; font-weight: 500; }

  /* full-bleed media */
  .he__media { margin: 0; }
  .he__media img { display: block; width: 100%; height: clamp(320px, 52vw, 620px); object-fit: cover; }

  /* light entrance animation — staggered */
  @keyframes heRise { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: none; } }
  @keyframes heMedia { from { opacity: 0; transform: translateY(24px) scale(0.995); } to { opacity: 1; transform: none; } }
  .he__anim { opacity: 0; animation: heRise 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards; animation-delay: var(--d, 0ms); }
  .he__media.he__anim { animation-name: heMedia; }

  @media (prefers-reduced-motion: reduce) {
    .he__anim { opacity: 1 !important; transform: none !important; animation: none !important; }
  }

  @media (max-width: 720px) {
    .he__links { display: none; }
    .he__burger { display: inline-flex; }
    .he.is-open .he__mobile { display: block; }

    .he__content { grid-template-columns: 1fr; padding-top: clamp(2.5rem, 9vw, 3.5rem); }
    .he__content > * { grid-column: 1; }
    .he__title { max-width: none; }

    .he__meta { grid-template-columns: 1fr; gap: 1.1rem; }
    .he__email { grid-column: 1; justify-self: start; }
    .he__facts { grid-column: 1; gap: 2.5rem; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.he').forEach((he) => {
    const burger = he.querySelector<HTMLButtonElement>('[data-he-burger]');
    const mobile = he.querySelector<HTMLElement>('[data-he-mobile]');
    burger?.addEventListener('click', () => {
      const open = he.classList.toggle('is-open');
      burger.setAttribute('aria-expanded', String(open));
      if (mobile) mobile.hidden = !open;
    });
  });
</script>
