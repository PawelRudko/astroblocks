---
// FeatureStackSections — each feature has a sticky "0X · Label" header row that accumulates at the top
// as you scroll (row N sticks below row N-1), while the feature content scrolls between them. Pure CSS
// (position: sticky, per-row offset = row index × row height). Responsive: static list on mobile. Edit by chat (AGENTS.md).
interface Btn { label: string; href?: string }
interface Feature {
  navLabel: string;
  eyebrow?: string;
  title: string;
  subtitle?: string;
  primary?: Btn;
  secondary?: Btn;
  image?: string;
}
interface Props { features: Feature[]; bg?: 'white' | 'gray' }
const { features, bg = 'white' } = Astro.props;
const ph = '/placeholder-landscape.svg';
const n = (i: number) => String(i + 1).padStart(2, '0');
---

<section class:list={['fss', `fss--${bg}`]}>
  <div class="fss__wrap">
    {features.map((f, i) => (
      <Fragment>
        <div class="fss__nav" style={`--i:${i}`}>
          <span class="fss__num">{n(i)}</span>
          <span class="fss__label">{f.navLabel}</span>
        </div>
        <div class="fss__content">
          <div class="fss__text">
            {f.eyebrow && <span class="eyebrow">{f.eyebrow}</span>}
            <h2 class="fss__title">{f.title}</h2>
            {f.subtitle && <p class="fss__lead">{f.subtitle}</p>}
            {(f.primary || f.secondary) && (
              <div class="fss__cta">
                {f.primary && <a class="btn btn--secondary" href={f.primary.href || '#'}>{f.primary.label}</a>}
                {f.secondary && <a class="btn btn--link" href={f.secondary.href || '#'}>{f.secondary.label} <span aria-hidden="true">→</span></a>}
              </div>
            )}
          </div>
          <div class="fss__media">
            <img src={f.image || ph} alt="" loading="lazy" />
            <span class="fss__badge" aria-hidden="true">{n(i)}</span>
          </div>
        </div>
      </Fragment>
    ))}
  </div>
</section>

<style>
  .fss { --rowH: 3.5rem; padding-bottom: clamp(2rem, 5vw, 4rem); }
  .fss--white { background: #ffffff; }
  .fss--gray { background: #f5f4f2; }
  .fss__wrap { max-width: var(--maxw, 1440px); margin-inline: auto; padding-inline: clamp(1.25rem, 4vw, 2.5rem); }

  /* Sticky nav row — accumulates at the top */
  .fss__nav {
    position: sticky; top: calc(var(--i) * var(--rowH)); z-index: 3;
    height: var(--rowH); box-sizing: border-box;
    display: flex; align-items: center; gap: 1.25rem;
    border-top: 1px solid var(--line);
    font-weight: 600; color: var(--text);
  }
  .fss--white .fss__nav { background: #ffffff; }
  .fss--gray .fss__nav { background: #f5f4f2; }
  .fss__num { font-family: var(--font-mono); font-size: 0.85rem; }
  .fss__label { text-decoration: underline; text-underline-offset: 3px; }

  /* Feature content between the sticky rows */
  .fss__content {
    position: relative; z-index: 1;
    display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 5vw, 4rem); align-items: center;
    min-height: 40vh; padding: clamp(1rem, 2vh, 1.75rem) 0;
  }
  .fss__title { margin-top: 0.8rem; }
  .fss__lead { margin-top: 1rem; max-width: 44ch; color: rgba(33, 32, 28, 0.66); font-size: 15px; line-height: 1.6; }
  .fss__cta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.7rem; margin-top: 1.8rem; }

  .fss__media { position: relative; }
  .fss__media img { width: 100%; aspect-ratio: 1 / 1; object-fit: cover; border-radius: var(--radius-card); border: 1px solid var(--line); background: #ececea; }
  .fss__badge { position: absolute; top: 0.9rem; right: 1.1rem; font-family: var(--font-display); font-size: 1.4rem; font-weight: 600; color: rgba(33, 32, 28, 0.28); }

  @media (max-width: 900px) {
    .fss__nav { position: static; height: auto; padding: 0.9rem 0; }
    .fss__content { grid-template-columns: 1fr; gap: clamp(1.5rem, 4vw, 2rem); min-height: 0; padding: clamp(1.5rem, 4vw, 2.5rem) 0; }
    .fss__media { order: -1; }
    .fss__media img { aspect-ratio: 16 / 10; }
  }
</style>
