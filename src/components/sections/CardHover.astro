---
// CardHover — siatka kart ze zdjęciem. Domyślnie numer + tytuł na obrazie; na hover (lub focus)
// od dołu wysuwa się biały panel z pełnym tekstem (numer + tytuł + opis). Bez zależności.
// Numer generuje się automatycznie (01, 02…), można nadpisać w danych. Edytuj rozmową (AGENTS.md).
interface Item { number?: string; title: string; description?: string; image?: string; href?: string }
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  items: Item[];
  bg?: 'white' | 'gray';
}
const { eyebrow, title, subtitle, items, bg = 'white' } = Astro.props;
const num = (it: Item, i: number) => it.number ?? String(i + 1).padStart(2, '0');
---

<section class:list={['cards', `cards--${bg}`]}>
  <div class="cards__wrap">
    <header class="cards__head">
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h2 class="cards__title">{title}</h2>
      {subtitle && <p class="cards__subtitle">{subtitle}</p>}
    </header>

    <div class="cards__grid">
      {items.map((it, i) => (
        <a class="card" href={it.href || '#'} style={`--d:${i * 80}ms`}>
          <div class="card__media">
            <img src={it.image || '/placeholder-landscape.svg'} alt="" loading="lazy" />
          </div>

          <div class="card__label">
            <sup class="card__num">{num(it, i)}</sup>
            <span class="card__label-title">{it.title}</span>
          </div>

          <div class="card__panel">
            <sup class="card__num card__num--dark">{num(it, i)}</sup>
            <h3 class="card__panel-title">{it.title}</h3>
            {it.description && <p class="card__panel-text">{it.description}</p>}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .cards { padding: clamp(3rem, 7vw, 6rem) 0; }
  .cards--white { background: #ffffff; }
  .cards--gray { background: #f5f4f2; }
  .cards__wrap { max-width: 1200px; margin-inline: auto; padding-inline: clamp(1.25rem, 4vw, 2.5rem); }

  .cards__head { max-width: 40ch; margin-bottom: clamp(1.75rem, 4vw, 2.75rem); }
  .cards__title { margin-top: 0.7rem; }
  .cards__subtitle { margin-top: 0.7rem; color: rgba(33, 32, 28, 0.62); font-size: 0.95rem; line-height: 1.55; }

  .cards__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1.25rem, 2.5vw, 2rem); }

  /* Karta */
  .card {
    position: relative; display: block; color: inherit;
    border-radius: var(--radius-card); overflow: hidden; background: #ececea;
    aspect-ratio: 1 / 1; isolation: isolate;
  }
  .card__media { position: absolute; inset: 0; }
  .card__media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1); }
  .card:hover .card__media img { transform: scale(1.05); }
  /* przyciemnienie u dołu — czytelność białego tekstu */
  .card::after {
    content: ''; position: absolute; inset: 0; z-index: 1; pointer-events: none;
    background: linear-gradient(to top, rgba(15, 15, 18, 0.62) 0%, rgba(15, 15, 18, 0.12) 34%, transparent 55%);
    transition: opacity 0.3s ease;
  }
  .card:hover::after, .card:focus-within::after { opacity: 0; }

  /* Numer (mono, superscript) */
  .card__num { font-family: var(--font-mono); font-size: 0.62rem; font-weight: 500; opacity: 0.8; vertical-align: 0.7em; margin-right: 0.15rem; }
  .card__num--dark { color: var(--text); opacity: 0.55; }

  /* Domyślna etykieta na obrazie */
  .card__label {
    position: absolute; z-index: 2; left: 0; right: 0; bottom: 0;
    display: flex; align-items: flex-start; gap: 0.1rem;
    padding: 1.15rem 1.25rem; color: #fff;
    transition: opacity 0.28s ease;
  }
  .card__label-title { font-family: var(--font-display); font-size: 1.0625rem; font-weight: 600; line-height: 1.3; letter-spacing: -0.01em; }
  .card:hover .card__label, .card:focus-within .card__label { opacity: 0; }

  /* Biały panel wysuwany od dołu */
  .card__panel {
    position: absolute; z-index: 3; left: 12px; right: 12px; bottom: 12px;
    background: #fff; border-radius: 12px; padding: 1.05rem 1.2rem 1.15rem;
    box-shadow: 0 18px 40px -18px rgba(15, 15, 18, 0.4);
    transform: translateY(calc(100% + 16px)); opacity: 0;
    transition: transform 0.42s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.28s ease;
  }
  .card:hover .card__panel, .card:focus-within .card__panel { transform: translateY(0); opacity: 1; }
  .card__panel-title { font-size: 1.0625rem; font-weight: 600; line-height: 1.3; letter-spacing: -0.01em; }
  .card__panel-text { margin-top: 0.4rem; color: rgba(33, 32, 28, 0.66); font-size: 0.9rem; line-height: 1.55; }

  /* Wejście */
  @keyframes cardRise { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: none; } }
  .card { opacity: 0; animation: cardRise 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards; animation-delay: var(--d, 0ms); }

  @media (prefers-reduced-motion: reduce) {
    .card { opacity: 1 !important; transform: none !important; animation: none !important; }
    .card__media img, .card__panel, .card__label, .card::after { transition: none; }
  }

  @media (max-width: 900px) { .cards__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .cards__grid { grid-template-columns: 1fr; } }
</style>
